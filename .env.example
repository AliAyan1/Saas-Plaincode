# ============================================
# Ecommerce Support in One Click - Environment
# Copy this file to .env.local and fill in your values
# ============================================

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Or use individual variables (if your app prefers):
DB_HOST="localhost"
DB_PORT="3306"
DB_USER="your_mysql_user"
DB_PASSWORD="your_mysql_password"
DB_NAME="ecommerce_support"

# OpenAI (for chat API)
OPENAI_API_KEY="sk-your-openai-api-key"

# Optional: Auth secret (for sessions/JWT)
AUTH_SECRET="your-random-secret-string-min-32-chars"

# Optional: App URL (for emails, redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -------------------------------------------
# Forwarded conversations → email (real working setup)
# -------------------------------------------
# 1. Sign up at https://resend.com (free tier: 100 emails/day).
# 2. In Resend dashboard: API Keys → Create → copy the key (starts with re_).
# 3. Paste it here (in .env.local):
RESEND_API_KEY="re_xxxxxxxxxxxx"

# 4. For testing only: leave EMAIL_FROM unset — Resend sends from onboarding@resend.dev.
# 5. For production: In Resend add your domain, verify DNS, then set a sender address:
EMAIL_FROM="support@yourdomain.com"

# 6. (Optional) Gmail reply → show in chat: use Resend Inbound. In Resend: Inbound → add address
#    (e.g. support@yourdomain.com). Set that same address as EMAIL_FROM above. Set webhook URL to:
#    https://your-domain.com/api/webhooks/resend-inbound
#    When support replies from Gmail to the forward email, the reply appears in the customer's chat.
